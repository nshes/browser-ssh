# Cloudflare Zero Trust team domain, for example: example.cloudflareaccess.com
BROWSER_SSH_ACCESS_TEAM_DOMAIN=replace.cloudflareaccess.com

# Application Audience (AUD) tag from the Cloudflare Access application.
BROWSER_SSH_ACCESS_AUDIENCE=replace-with-access-aud

# Exact public origin. Keep this synchronized with the Cloudflare public hostname.
BROWSER_SSH_PUBLIC_ORIGIN=https://ssh.example.com

# Defense-in-depth whitelist checked again after the Access JWT is validated.
# Use a comma-separated list when more than one mailbox is allowed.
BROWSER_SSH_ALLOWED_EMAILS=replace@example.com

BROWSER_SSH_HOME=/home/browser-ssh
BROWSER_SSH_TARGET_ID=default
BROWSER_SSH_TARGET_NAME=Primary server
BROWSER_SSH_UPLOAD_PATH=/home/operator/uploads/
BROWSER_SSH_DOWNLOAD_PATH=/home/operator
BROWSER_SSH_COMMAND=/home/browser-ssh/bin/browser-ssh-broker-client
BROWSER_SSH_BROKER_HOST=127.0.0.1
BROWSER_SSH_BROKER_PORT=10022
BROWSER_SSH_BROKER_USER=browser-ssh-broker
BROWSER_SSH_BROKER_KEY=/etc/browser-ssh-gateway/broker-client-key
BROWSER_SSH_BROKER_KNOWN_HOSTS=/etc/browser-ssh-gateway/broker-known-hosts
BROWSER_SSH_IDLE_TIMEOUT=PT15M
BROWSER_SSH_MAX_SESSION_DURATION=PT2H
BROWSER_SSH_MAX_CONCURRENT_SESSIONS=2
BROWSER_SSH_MAX_INPUT_CHARACTERS=16384
BROWSER_SSH_MAX_MESSAGES_PER_SECOND=300
BROWSER_SSH_MAX_TRANSFER_CONNECTIONS=2
BROWSER_SSH_MAX_TRANSFER_OPERATIONS=2
# Applies only to the short-lived file-transfer WebSocket, not terminal sessions.
BROWSER_SSH_TRANSFER_IDLE_TIMEOUT=PT1M
